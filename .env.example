# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://boostins:secret@localhost:5432/boostins
POSTGRES_DB=boostins
POSTGRES_USER=boostins
POSTGRES_PASSWORD=secret

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Encryption ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=32_char_random_hex_string_here!!

# ─── Admin ──────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@boostins.com
ADMIN_PASSWORD=Admin@123456

# ─── MercadoPago ────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=your_mercadopago_access_token
MP_PUBLIC_KEY=your_mercadopago_public_key
NEXT_PUBLIC_MP_PUBLIC_KEY=your_mercadopago_public_key

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="BoostIns <noreply@boostins.com>"

# ─── Provider API ────────────────────────────────────────────────────────────
# These are seeded via the Admin Dashboard after setup
DEFAULT_PROVIDER_NAME=MyProvider
DEFAULT_PROVIDER_URL=https://provider.example.com/api/v2
DEFAULT_PROVIDER_KEY=your_provider_api_key

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Referral ────────────────────────────────────────────────────────────────
REFERRAL_REWARD_AMOUNT=5.00
